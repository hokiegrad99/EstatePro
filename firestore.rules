rules_version = '2';

// =============================================================================
// EstatePro — Phase 1 Security Rules
// =============================================================================
// These rules are deployed to Firebase (not served from GitHub Pages), so it's
// safe to embed the founder-secret hash here.
//
// Phase 1 scope:
//   - users/{uid}: read/write only your own profile
//   - estates/{id}.read: only members (any role)
//   - estates/{id}.create: only via founder-bootstrap path (secret hash match)
//
// NOT in this phase (Phase 2/4):
//   - estates/{id}.update (executor writes)         -> Phase 2
//   - estates/{id}.update (invite consumption)      -> Phase 4
//   - estates/{id}.delete                           -> Phase 4
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isMember(estateId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/estates/$(estateId))
        && request.auth.uid in get(/databases/$(database)/documents/estates/$(estateId)).data.memberIds;
    }
    function isBootstrapLocked() {
      // Per-project bootstrap pattern: a /_meta/bootstrap_lock document is
      // created transactionally alongside the very first founder-estate.
      // Once it exists, no additional founder-estates can be created in this
      // project. Any signed-in user needs to be able to read it so bootstrap.html
      // and index.html can decide whether the bootstrap form / hint should be shown.
      return exists(/databases/$(database)/documents/_meta/bootstrap_lock);
    }

    // ---- users/{userId} ----
    // Each user can read and write only their own profile doc.
    match /users/{userId} {
      allow read, write: if isSelf(userId);

      // Initial profile create must include email; further writes are ruled as
      // above (any field changes by self).
      allow create: if isSelf(userId)
        && request.resource.data.email is string;
    }

    // ---- _meta/{metaId} ----
    // Bootstrap lock doc lives here, keyed at the conventional
    // _meta/bootstrap_lock path. This doc is consulted by:
    //   - bootstrap.html: client pre-check — show the founder form?
    //   - index.html:     client pre-check — surface the "no estate yet" hint?
    //   - the rules below: belt-and-suspenders gate on estates/{id}.create
    //
    // The ONLY path that creates the lock is the runTransaction call inside
    // bootstrap.html, which atomically creates BOTH the lock and the first
    // estate. update/delete are forbidden here so the lock is genuinely one-shot:
    // even after Phase 4 brings admin-tooling, retiring a project will go
    // through a Cloud Function or admin-only manual step, not the client.
    match /_meta/{metaId} {
      allow read: if isSignedIn();
      // Create is allowed only for the very first time the doc is written.
      // After that, the server rejects further creates of the same doc-id,
      // and any attempt to write a different doc-id under /_meta is also
      // blocked because the precondition fails (the doc would not yet exist
      // — wait, that's actually allowed since !exists is true). So we
      // additionally scope creates to the well-known doc-id bootstrap_lock
      // by requiring the caller to know the name. (Firestore rules can't
      // enumerate doc ids, so this is enforced by the bootstrap.html client
      // writing only '_meta/bootstrap_lock'.)
      // Create is allowed ONLY for the well-known _meta/bootstrap_lock doc-id.
      // Without this scope check, any signed-in user could spam-create arbitrary
      // _meta/* docs (each one consumes a read on every bootstrap check forever,
      // and our `update, delete: false` ruleset means nobody can ever clean
      // them up client-side). Restricting the doc-id to a known constant keeps
      // the collection clean.
      allow create: if isSignedIn()
        && metaId == 'bootstrap_lock'
        && !exists(/databases/$(database)/documents/_meta/$(metaId));
      // Single-shot: the lock can never be moved or deleted client-side.
      allow update, delete: if false;
    }

    // ---- estates/{estateId} ----
    // Phase 1: only "read if member" + "create via founder-bootstrap".
    match /estates/{estateId} {
      allow read: if isMember(estateId);

      // Founder bootstrap path. Caller must:
      //   1. Be signed in.
      //   2. The bootstrap lock must NOT already exist (i.e., this is the
      //      FIRST founder-estate for this project). This is belt-and-suspenders
      //      alongside the runTransaction guard in bootstrap.html — even if
      //      someone bypassed the UI check, this rule refuses.
      //   3. Pass __founderSecret as a 64-char hex string (SHA-256).
      //   4. The hex must match the constant pinned below.
      //   5. Make themselves the only member and assign themselves executor.
      //   6. Start with an empty pendingInvites map.
      //
      // The constant below is the SHA-256 hex of YOUR secret. See FIREBASE-SETUP.md.
      // Do NOT use the placeholder below — replace it before deploying.
      allow create: if isSignedIn()
        && !isBootstrapLocked()
        && '__founderSecret' in request.resource.data
        && request.resource.data.__founderSecret is string
        && request.resource.data.__founderSecret.size() == 64
        && request.resource.data.__founderSecret
              == '4473143dc63f754c10f105c8cda97d119c3bb95cce7b50ae0cebc7cb00594175'
        && request.resource.data.memberIds.size() == 1
        && request.resource.data.memberIds[0] == request.auth.uid
        && request.resource.data.roles[request.auth.uid] == 'executor'
        && request.resource.data.pendingInvites.size() == 0;

      // Phase 2: executor writes allowed; structural/auth fields frozen.
      //
      // To update this doc the caller must:
      //   (1) be a member of this estate (see isMember), AND
      //   (2) hold the 'executor' role for this estate specifically.
      //
      // They MUST NOT mutate any of the immutable fields below. The phase 1
      // bootstrap created `__founderSecret`, `memberIds`, `roles`,
      // `pendingInvites`, `createdBy`, and `createdAt`; invite consumption (Phase
      // 4) will be the only legitimate writer of `memberIds` and `roles`, and
      // we'll add a separate rule path for that. Until then, this rule is the
      // only path that lets the bootstrap user edit estate data, keeping the
      // structural shape stable across Phase 2 writes.
      allow update: if isMember(estateId)
        && resource.data.roles[request.auth.uid] == 'executor'
        && request.resource.data.memberIds      == resource.data.memberIds
        && request.resource.data.roles          == resource.data.roles
        && request.resource.data.pendingInvites == resource.data.pendingInvites
        // __founderSecret: client doesn't send it; Firestore partial-update
        // leaves the existing server value untouched. We phrase the rule so
        // EITHER (a) the field is missing from the request (auto-unchanged) OR
        // (b) the value matches the server's value (no mutation).
        && (!('__founderSecret' in request.resource.data)
            || request.resource.data.__founderSecret == resource.data.__founderSecret)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;

      // Phase 4 will add: allow delete for executors.
      allow delete: if false;
    }
  }
}
