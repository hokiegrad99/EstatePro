rules_version = '2';

// =============================================================================
// EstatePro — Phase 1 Security Rules
// =============================================================================
// These rules are deployed to Firebase (not served from GitHub Pages), so it's
// safe to embed the founder-secret hash here.
//
// Phase 1 scope:
//   - users/{uid}: read/write only your own profile
//   - estates/{id}.read: only members (any role)
//   - estates/{id}.create: only via founder-bootstrap path (secret hash match)
//
// NOT in this phase (Phase 2/4):
//   - estates/{id}.update (executor writes)         -> Phase 2
//   - estates/{id}.update (invite consumption)      -> Phase 4
//   - estates/{id}.delete                           -> Phase 4
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isMember(estateId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/estates/$(estateId))
        && request.auth.uid in get(/databases/$(database)/documents/estates/$(estateId)).data.memberIds;
    }
    function isBootstrapLocked() {
      // Per-project bootstrap pattern: a /_meta/bootstrap_lock document is
      // created transactionally alongside the very first founder-estate.
      // Once it exists, no additional founder-estates can be created in this
      // project. Any signed-in user needs to be able to read it so bootstrap.html
      // and index.html can decide whether the bootstrap form / hint should be shown.
      return exists(/databases/$(database)/documents/_meta/bootstrap_lock);
    }

    // ---- Phase 6: Platform Admin role ----
    // A user holds Admin powers when their /users/{uid}.isAdmin == true.
    // This is a GLOBAL flag (not per-estate). Admin can write any per-estate
    // the way an executor can, AND can mint additional estates (bypassing the
    // bootstrap_lock AND the __founderSecret check).
    function isPlatformAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
        // Phase 8: a soft-deleted Admin loses their powers the moment the
        // /users/{uid}.isDeleted flag flips to true, even though their
        // Firebase Auth account might still be alive. We pair this with
        // sendPasswordResetEmail in App.Auth.deleteUser so the existing
        // session becomes useless for the next login.
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isDeleted', false) == false;
    }
    // ---- Phase 8: soft-delete target validator ----
    // Lets an Admin set {isDeleted, deletedAt, deletedBy, updatedAt} on
    // /users/{userId} via a single .update(). userId != self blocks the
    // Admin from accidentally orphaning themselves through this path
    // (the isSelf branch in /users/{userId}.update ALSO refuses
    // isDeleted flips as a defense-in-depth double). Affected-keys check
    // makes sure no other field can be smuggled in alongside the four
    // soft-delete flags.
    function isSoftDeleteTarget(userId) {
      return isSignedIn()
        && isPlatformAdmin()
        && userId != request.auth.uid
        && request.resource.data.get('isDeleted', false) == true
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isDeleted', 'deletedAt', 'deletedBy', 'updatedAt']);
    }
    // First-claim one-shot. A signed-in user can self-write
    // {isAdmin:true, isAdminClaimed:true} ONLY when no platform_admin_lock
    // exists yet, AND the transaction writes the lock atomically. existsAfter()
    // forces that atomicity -- a malicious client issuing a single .update()
    // without runTransaction is rejected because the rule-engine can't observe
    // the lock being written in the same request. After the lock exists, this
    // branch is dead and an attacker can never mint themselves an Admin.
    // First-claim one-shot. A signed-in user can self-write
    // {isAdmin:true, isAdminClaimed:true} ONLY when no platform_admin_lock
    // exists yet, AND the transaction writes the lock atomically. existsAfter()
    // forces that atomicity -- a malicious client issuing a single .update()
    // without runTransaction is rejected because the rule-engine can't observe
    // the lock being written in the same request. After the lock exists, this
    // branch is dead and an attacker can never mint themselves an Admin.
    //
    // Phase 6 linter fix: pass `userId` as an explicit parameter. Earlier
    // version referenced `userId` directly from the function body, which
    // the Firestore CEL engine rejects with "[W] Invalid variable name:
    // userId" -- function bodies do not capture path wildcards from match
    // blocks (same root cause as the earlier `affectedKeys()[0]` warning).
    // The callers are in `match /users/{userId}`, so they pass the value
    // through explicitly here.
    function claimFirstAdmin(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && !exists(/databases/$(database)/documents/_meta/platform_admin_lock)
        && request.resource.data.get('isAdmin', false) == true
        && request.resource.data.get('isAdminClaimed', false) == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdmin', 'isAdminClaimed', 'updatedAt'])
        && existsAfter(/databases/$(database)/documents/_meta/platform_admin_lock);
    }

    // ---- Phase 3 hardening: per-field shape validation ----
    // The Phase 2 executor-write rule froze memberIds/roles/pendingInvites/
    // __founderSecret/createdBy/createdAt but did NOT validate that the four
    // data collections (tasks/assets/debts/cashflow/heirs) stay arrays nor
    // that decedent/executor stay objects. A compromised executor could
    // therefore overwrite them with arbitrary types ('junk' / 42 / null) and
    // crash the next render loop. Phase 4 will additionally let invite
    // consumption mutate memberIds/roles -- which is why we tighten the rule
    // HERE so the new writer path inherits the same shape guarantees.
    //
    // Notes on Firestore rules v2 syntax:
    //   - `data.foo is list` returns FALSE (not throws) when foo is missing.
    //     We use data.get('foo', null) for clarity: if the field is absent,
    //     data.get returns the null default, which is not a list, so the
    //     rule fails loudly with a "missing field" rather than silently
    //     failing on the type check.
    //   - Array-of-object schema validation (each task has a title, each
    //     asset has a value, etc.) is intentionally NOT enforced in rules.
    //     Firestore can't cheaply walk nested arrays; that's the client's
    //     job (App.Data._normalize + render loop).
    //
    // Sizing rationale (free Tier / Spark plan) -- cap per-field so a
    // malicious executor can't push a 1MB doc write that breaks free-tier
    // document-size limits or inflates read costs:
    //   tasks / assets / debts / heirs / distributions   <= 1000 each
    //   cashflow (transaction ledger)                   <= 10000
    //   memberIds (people with access)                  <= 100
    function isValidEstateShape(data) {
      return data.get('tasks', null)         is list && data.tasks.size()         <= 1000
          && data.get('assets', null)        is list && data.assets.size()        <= 1000
          && data.get('debts', null)         is list && data.debts.size()         <= 1000
          && data.get('heirs', null)         is list && data.heirs.size()         <= 1000
          && data.get('distributions', null) is list && data.distributions.size() <= 1000
          && data.get('cashflow', null)      is list && data.cashflow.size()      <= 10000
          && data.get('decedent', null)      is map
          && data.get('executor', null)      is map
          && data.get('memberIds', null)     is list && data.memberIds.size()     <= 100
          && data.get('roles', null)         is map
          && data.get('pendingInvites', null) is map;
    }

    // ---- Phase 4 helper: invite consumption ----
    // Validates the legitimate-pattern of a NEW member joining via an
    // accepted invite. Compares resource (server state before the write)
    // against request.resource (after-the-write client intent). Firestore
    // rules can't deep-validate the matching subdoc atomically, so the
    // client performs a single runTransaction that marks the invite subdoc's
    // redeemedBy/redeemedAt AT THE SAME TIME as the parent doc update --
    // if either write fails server-side, both roll back.
    function isInviteConsumption() {
      let uid = request.auth.uid;
      return isSignedIn()
        // The joiner must not already be a member (prevents replay/double-add).
        && !(uid in resource.data.memberIds)
        // Exactly one member added and it is THIS signer.
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && request.resource.data.memberIds[request.resource.data.memberIds.size() - 1] == uid
        // A non-null role string is assigned (executor/heir/beneficiary).
        && request.resource.data.roles[uid] is string
        && (request.resource.data.roles[uid] in ['executor', 'heir', 'beneficiary']);
        // NOTE: pendingInvites.size() decrement intentionally NOT enforced.
        // The subcollection /estates/{id}/invites/ is the source of truth
        // for outstanding invitations. The parent doc's pendingInvites is a
        // denormalized cache populated only when createInvite travels through
        // the (optional) createInviteLink Cloud Function, which uses Admin
        // SDK to atomically write both the subdoc and the cache key. The
        // direct App.Auth.Invite.createInvite path writes only the subdoc and
        // leaves pendingInvites untouched on the parent -- so a strict
        // size-decrement check would unconditionally reject every legitimate
        // consume. Strict symmetry is restored once createInvite is migrated
        // end-to-end to the Cloud Function path; until then, the ruleset
        // intentionally trusts the subcollection redeem-pattern.
    }

    // ---- Phase 5 helpers ----
    // The two helpers below extend the existing /estates/{estateId} update rule
    // with executor-only mutations of the membership state. We deliberately
    // keep the diff constraints tight so the existing executor-write branch's
    // safety guarantees (frozen pendingInvites / __founderSecret / createdBy /
    // createdAt) are preserved unchanged. Both new helpers gate on the executor
    // role for this specific estate and use a "last executor" guard so the
    // estate can never become write-locked from the client side. Retiring the
    // entire estate is intentionally NOT supported from the client; it goes
    // through a future Cloud Function with admin privileges.
    function isModifyMemberRole(estateId) {
      let rolesDiff = request.resource.data.roles.diff(resource.data.roles);
      return isSignedIn()
        // Phase 6: Admin powers are global -- an Admin can run this branch
        // on any estate whether they're a member or not. The last-executor
        // guard below still applies even to Admins (you can't orphan an
        // estate even with Admin authority).
        && (isPlatformAdmin() || isMember(estateId))
        && (isPlatformAdmin() || resource.data.roles[request.auth.uid] == 'executor')
        // Exactly one role key's value changed; no adds, no removes.
        // We use addedKeys()/removedKeys()/changedKeys()/.size() instead of
        // indexing `affectedKeys()[0]` because Firestore's CEL engine returns
        // `affectedKeys()` as a SET (confirmed by linter warning: "Received
        // one of [set]"). [0] indexing on a set is a runtime error, which the
        // engine silently turns into permission denied — the exact symptom
        // that surfaced on first deploy.
        && rolesDiff.addedKeys().size()   == 0
        && rolesDiff.removedKeys().size() == 0
        && rolesDiff.changedKeys().size() == 1
        // Every value in the new roles map must be a valid role (catches role spoofing).
        && request.resource.data.roles.values().hasOnly(['executor', 'heir', 'beneficiary'])
        // Last-executor guard: if an executor existed before, must remain after.
        && (resource.data.roles.values().hasAny(['executor'])
              ? request.resource.data.roles.values().hasAny(['executor'])
              : true)
        // memberIds / pendingInvites / structural fields unchanged.
        && request.resource.data.memberIds      == resource.data.memberIds
        && request.resource.data.pendingInvites == resource.data.pendingInvites
        && (!('__founderSecret' in request.resource.data)
            || request.resource.data.__founderSecret == resource.data.__founderSecret)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidEstateShape(request.resource.data);
    }

    function isRemoveMember(estateId) {
      let rolesDiff = request.resource.data.roles.diff(resource.data.roles);
      return isSignedIn()
        // Phase 6: Admins can remove members from any estate. Last-executor
        // guard below remains in effect even for Admins.
        && (isPlatformAdmin() || isMember(estateId))
        && (isPlatformAdmin() || resource.data.roles[request.auth.uid] == 'executor')
        // Exactly one member removed from BOTH memberIds and roles keys.
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
        && request.resource.data.roles.size()     == resource.data.roles.size()     - 1
        // Roles diff: exactly one key REMOVED (not changed, not added). Same
        // set-vs-list bypass as isModifyMemberRole -- never index the diff.
        && rolesDiff.addedKeys().size()   == 0
        && rolesDiff.changedKeys().size() == 0
        && rolesDiff.removedKeys().size() == 1
        // Cross-consistency: every memberId must have a role entry. Catches the
        // "remove A from memberIds but accidentally remove the wrong uid from
        // roles" ghost-member scenario. Strictly tighter than the previous
        // addedItems().size()==0 check (impossible here, since the Firestore
        // CEL engine rejects "+addedItems()" with "[W] Invalid function name").
        && request.resource.data.roles.keys().hasAll(request.resource.data.memberIds)
        // Remaining roles all valid.
        && request.resource.data.roles.values().hasOnly(['executor', 'heir', 'beneficiary'])
        // Last-executor guard.
        && (resource.data.roles.values().hasAny(['executor'])
              ? request.resource.data.roles.values().hasAny(['executor'])
              : true)
        // pendingInvites / structural fields unchanged.
        && request.resource.data.pendingInvites == resource.data.pendingInvites
        && (!('__founderSecret' in request.resource.data)
            || request.resource.data.__founderSecret == resource.data.__founderSecret)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidEstateShape(request.resource.data);
    }

    // ---- users/{userId} ----
    // Each user can read and write only their own profile doc.
    match /users/{userId} {
      // Admins can read every user's profile (for platform-management UI),
      // and update every user profile (typo fixes, demoting another admin,
      // promoting another admin onto the platform, etc.). The promotion
      // case bypasses claimFirstAdmin: an existing admin writing isAdmin=true
      // to another user is allowed by the isPlatformAdmin() branch.
      allow read: if isSelf(userId) || isPlatformAdmin();
      allow create: if isSelf(userId)
        && request.resource.data.email is string;
      // Phase 8 update rule: each OR-branch has a specific job.
      //   - isSelf branch lets the user typo-fix their own profile
      //     (displayName, email) but REFUSES isDeleted flips on yourself
      //     (an Admin shouldn't be able to self-flag -- another Admin
      //     must do it via isSoftDeleteTarget below; the in-place check
      //     here is a defense-in-depth because isSelf fires first in
      //     OR short-circuit and would otherwise let the Admin pass).
      //   - isPlatformAdmin branch lets any current Admin update any user.
      //   - claimFirstAdmin branch closes the one-time founder-claim race.
      //   - isSoftDeleteTarget branch is the structured soft-delete path
      //     (4-key whitelist + userId != self). Admins clicking Delete
      //     in the UI flow through this branch and leave a tidy audit
      //     log with deletedAt / deletedBy / updatedAt.
      allow update: if (isSelf(userId)
        && request.resource.data.get('isDeleted', false)
           == resource.data.get('isDeleted', false))
        || (isPlatformAdmin() && request.auth.uid != userId)
        // Phase 6 NEW OR-branch: first-ever self-claim to Admin.
        // Atomicity is enforced at the server: rule demands that the
        // transaction also write /_meta/platform_admin_lock (existsAfter);
        // the lock is the locking primitive that closes the race condition
        // for first-claim because it's !exists on entry and one-create-only.
        // Phase 6 linter fix: pass userId explicitly to claimFirstAdmin().
        || claimFirstAdmin(userId)
        // Phase 8 NEW OR-branch: explicit soft-delete via 4-key
        // affectedKeys set. See isSoftDeleteTarget() above for the
        // self-block + affected-keys whitelist rationale.
        || isSoftDeleteTarget(userId);
      // Phase 8: open delete to admins as well, so a Phase-8+ admin tool
      // (or SDK script) can hard-delete a /users/{uid} doc if needed.
      // The default UI flow uses soft-delete (isDeleted flag), which keeps
      // an audit trail and lets a future undelete feature work.
      allow delete: if isSelf(userId) || isPlatformAdmin();
    }

    // ---- _meta/{metaId} ----
    // Bootstrap lock doc lives here, keyed at the conventional
    // _meta/bootstrap_lock path. This doc is consulted by:
    //   - bootstrap.html: client pre-check — show the founder form?
    //   - index.html:     client pre-check — surface the "no estate yet" hint?
    //   - the rules below: belt-and-suspenders gate on estates/{id}.create
    //
    // The ONLY path that creates the lock is the runTransaction call inside
    // bootstrap.html, which atomically creates BOTH the lock and the first
    // estate. update/delete are forbidden here so the lock is genuinely one-shot:
    // even after Phase 4 brings admin-tooling, retiring a project will go
    // through a Cloud Function or admin-only manual step, not the client.
    // Two distinct /_meta docs, each one-shot:
    //   bootstrap_lock -- immutably frozen (founder-bootstrap gate, original
    //     behavior, one-shot forever).
    //   platform_admin_lock -- created atomically by the first admin self-
    //     claim (existsAfter check on /users/{uid}.update), and editable by
    //     an existing Admin (so we can rotate the platform-admin identity
    //     later if needed). Until written, anyone signed in may attempt a
    //     runTransaction to install the first admin; after it exists, the
    //     runTransaction fails and claimFirstAdmin's branch is dead.
    match /_meta/bootstrap_lock {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/_meta/bootstrap_lock);
      allow update, delete: if false;
    }
    match /_meta/platform_admin_lock {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !exists(/databases/$(database)/documents/_meta/platform_admin_lock);
      allow update, delete: if isPlatformAdmin();
    }

    // ---- estates/{estateId} ----
    // Phase 1: only "read if member" + "create via founder-bootstrap".
    match /estates/{estateId} {
      // Phase 4 fix (array-contains query optimization).
      //
      // The earlier `      // Phase 4 array-contains query fix.
      //
      // The earlier `allow read: if isMember(estateId);` invoked Firestore's
      // cross-doc `get()` inside a rule reached via App.Auth.getMyEstates's
      // `array-contains` query. The engine can't fold a get()-bearing rule
      // into the index/array-contains optimization pass, so it gave up and
      // rejected the query with "Missing or insufficient permissions" --
      // symptom: executor.html showed zero estates, role gate hid the
      // create-invite card, even though the user had an Estate 1 doc with
      // their uid in `memberIds[0]`.
      //
      // Replace the cross-doc get() with a self-only check (`resource.data`
      // is the doc being read, so it's well-defined for a per-doc rule
      // and folds into the array-contains optimization). `resource` is
      // null when the doc doesn't exist, which is exactly the intent of
      // the original `exists(...estates/{estateId}) && ...memberIds` gate,
      // so the new rule is equivalent for reads.
      //
      // Cross-doc `get()` is still used by:
      //   - the executor-write branch on `/estates/{estateId}` (writes
      //     don't go through array-contains optimization),
      //   - `/invites/{inviteId}` create/delete rules
      //     (same reason -- writes),
      //   - `/invites/{inviteId}` read rule (subcollection reads don't
      //     hit array-contains, so get() works there too).
      // Phase 4 array-contains fix: rules used cross-doc get() which Firestore cannot fold into an array-contains query; self-only check against resource.data.memberIds folds in and is equivalent for reads.
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      // Founder bootstrap path. Caller must:
      //   1. Be signed in.
      //   2. The bootstrap lock must NOT already exist (i.e., this is the
      //      FIRST founder-estate for this project). This is belt-and-suspenders
      //      alongside the runTransaction guard in bootstrap.html — even if
      //      someone bypassed the UI check, this rule refuses.
      //   3. Pass __founderSecret as a 64-char hex string (SHA-256).
      //   4. The hex must match the constant pinned below.
      //   5. Make themselves the only member and assign themselves executor.
      //   6. Start with an empty pendingInvites map.
      //
      // The constant below is the SHA-256 hex of YOUR secret. See FIREBASE-SETUP.md.
      // Do NOT use the placeholder below — replace it before deploying.
      allow create: if isSignedIn()
        && (
          // Phase 1: founder-bootstrap path. Only the FIRST founder estate,
          // gated by !isBootstrapLocked() AND the __founderSecret hash below.
          (!isBootstrapLocked()
            && '__founderSecret' in request.resource.data
            && request.resource.data.__founderSecret is string
            && request.resource.data.__founderSecret.size() == 64
            && request.resource.data.__founderSecret
              == '33369ae700b2b16f4e0c6fe93620afa30102b958786b496bf042a901de0dda72'
            && request.resource.data.memberIds.size() == 1
            && request.resource.data.memberIds[0] == request.auth.uid
            && request.resource.data.roles[request.auth.uid] == 'executor'
            && request.resource.data.pendingInvites.size() == 0
            && isValidEstateShape(request.resource.data))
          // Phase 6 NEW OR-branch: any existing platform Admin may mint a
          // new estate. They skip the bootstrap-secret (their Admin status
          // is the credential) but still must be the sole executor and the
          // shape validator must pass. Each Admin-created estate gets its
          // own Firestore auto-id; nothing in this branch reads or inherits
          // __founderSecret from the founder-bootstrap estate.
          || (isPlatformAdmin()
            // Phase 6 advisory fix: explicitly REJECT the founder-bootstrap
            // secret on the admin path. Without this, an admin who knows the
            // founder-secret hash could accidentally stash it in a new estate
            // doc, which would then leak the secret value to any member of
            // that new estate via the standard read rule. Admins minting an
            // estate never need __founderSecret -- their Admin status is the
            // credential. We forbid the field entirely on this branch.
            && !('__founderSecret' in request.resource.data)
            && request.resource.data.memberIds.size() == 1
            && request.resource.data.memberIds[0] == request.auth.uid
            && request.resource.data.roles[request.auth.uid] == 'executor'
            && request.resource.data.pendingInvites.size() == 0
            && isValidEstateShape(request.resource.data))
        );

      // Phase 2: executor writes allowed; structural/auth fields frozen.
      //
      // To update this doc the caller must:
      //   (1) be a member of this estate (see isMember), AND
      //   (2) hold the 'executor' role for this estate specifically.
      //
      // They MUST NOT mutate any of the immutable fields below. The phase 1
      // bootstrap created `__founderSecret`, `memberIds`, `roles`,
      // `pendingInvites`, `createdBy`, and `createdAt`; invite consumption (Phase
      // 4) will be the only legitimate writer of `memberIds` and `roles`, and
      // we'll add a separate rule path for that. Until then, this rule is the
      // only path that lets the bootstrap user edit estate data, keeping the
      // structural shape stable across Phase 2 writes.
      // Phase 6: Admin branch is NOT a top-level short-circuit. Earlier draft
      // wrote `if isPlatformAdmin() || (...)` -- that bypassed every frozen-
      // field clause (last-executor guard via isModifyMemberRole, shape
      // validator) because the OR chain short-circuited as soon as the admin
      // check passed. The corrected shape below treats Admin as its own
      // self-contained check that enforces the SAME frozen-fields chain as
      // the executor-write branch. Admins have GLOBAL authority (no
      // isMember / role==executor required) but not UNCHECKED authority:
      //   - they must satisfy isValidEstateShape (tasks/assets/debts stay
      //     arrays, decedent/executor stay maps, memberIds/roles/
      //     pendingInvites stay lists/maps of bounded size);
      //   - they cannot mutate memberIds, roles, pendingInvites,
      //     __founderSecret, createdBy, or createdAt;
      //   - the last-executor guard inside isModifyMemberRole / isRemoveMember
      //     is unchanged and STILL FIRES for admins (you cannot orphan an
      //     estate even with platform Admin authority).
      // The Phase 4 consume-invite branch is intentionally left without a
      // separate admin prefix: admin can't impersonate invitees for
      // consumption because their auth.email won't match the invitee's
      // email -- the consume rule relies on email matching, not on the
      // role check.
      allow update: if (isPlatformAdmin()
        && request.resource.data.memberIds      == resource.data.memberIds
        && request.resource.data.roles          == resource.data.roles
        && request.resource.data.pendingInvites == resource.data.pendingInvites
        && (!('__founderSecret' in request.resource.data)
            || request.resource.data.__founderSecret == resource.data.__founderSecret)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidEstateShape(request.resource.data))
        // Phase 2 executor-write branch (legacy, unchanged).
        || (isMember(estateId)
        && resource.data.roles[request.auth.uid] == 'executor'
        // The Phase 2 frozen-fields chain: the executor-writing path can
        // edit tasks/assets/debts/cashflow/heirs/decedent/executor BUT NOT
        // touch the structural / auth fields below.
        && request.resource.data.memberIds      == resource.data.memberIds
        && request.resource.data.roles          == resource.data.roles
        && request.resource.data.pendingInvites == resource.data.pendingInvites
        // __founderSecret: client doesn't send it; Firestore partial-update
        // leaves the existing server value untouched. We phrase the rule so
        // EITHER (a) the field is missing from the request (auto-unchanged) OR
        // (b) the value matches the server's value (no mutation).
        && (!('__founderSecret' in request.resource.data)
            || request.resource.data.__founderSecret == resource.data.__founderSecret)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && isValidEstateShape(request.resource.data))
        // ---- Phase 4 NEW OR-branch ----
        // Allow a NEW member to mutate memberIds + roles + pendingInvites IF
        // and only if the diff matches the consume-invite shape (one member
        // added, one pending-invite removed, nested invite subdoc claimed
        // atomically client-side via runTransaction).
        || (isInviteConsumption()
            // Invite-consume allow pendingInvites to SHRINK by exactly one
            // (the consumed inviteId key cleanup, written via dot-notation
            // FieldValue.delete() in App.Auth.consumeInviteFromUrl) or to
            // stay at the same size (if the parent map didn't track this
            // specific inviteId -- the direct createInvite path populates
            // only the subcollection, not the parent map; the cache is
            // populated only when going through createInviteLink Cloud
            // Function). We must NOT allow growth because a joiner doing so
            // would be hijacking executor invite-issuance authority.
            // Equality is NOT valid here (the legitimate flow mutates the
            // map) and `==` is too strict for the dot-notation delete case.
            && (!('pendingInvites' in request.resource.data)
                || request.resource.data.pendingInvites.size()
                   <= resource.data.pendingInvites.size())
            && isValidEstateShape(request.resource.data))
        // ---- Phase 5 NEW OR-branches ----
        // Executor changes a single member's role OR removes a single member.
        // Both branches use isValidEstateShape to enforce the same Phase-3
        // schema invariants as the executor-write and consume-invite paths.
        || (isModifyMemberRole(estateId)
            && isValidEstateShape(request.resource.data))
        || (isRemoveMember(estateId)
            && isValidEstateShape(request.resource.data));

      // Phase 9: the executor of THIS specific estate OR any platform
      // Admin can permanently delete the doc. Mirrors the UI gate in
      // App.Permissions.canDeleteEstate. Subcollection cleanup is the
      // client-side App.Data.deleteEstate's responsibility: executor +
      // platform-admin can batch-delete UNREDEEMED invites (the
      // /invites/{inviteId}.delete rule permits executor + redeemedBy
      // == null); previously-redeemed invites are NOT deletable by an
      // executor and will remain as cloud orphans -- surfaced via the
      // helper's `redeemedInviteOrphans` count for transparency. There
      // is no .delete on /_meta docs from this rule path (those are
      // handled by their own match blocks).
      allow delete: if (isPlatformAdmin()
        || (isMember(estateId)
            && resource.data.roles[request.auth.uid] == 'executor'));

      // ---- /estates/{estateId}/invites/{inviteId} subcollection ----
      // Phase 4 sub-system 1: invite storage. Each invite is a thin envelope
      // created by the executor (or createInviteLink Cloud Function) and
      // claimed by the invitee in a single runTransaction against this doc
      // and the parent. The atomic consume gives us atomicity the ruleset
      // can't provide cross-document.
      match /invites/{inviteId} {
        // Read: any signed-in user can see the doc IF they're a member of the
        // parent estate OR their email matches what's being offered to them.
        // (We don't want any random signed-in user enumerating invites.)
        // Phase 4 fix: case- and whitespace-insensitive email comparison.
        // The previous strict `==` rejected consume-update attempts when the
        // executor's form input stored one case (e.g. "Tester1@Outlook.com")
        // and the heir's auth token email was another (e.g. lowercase). The
        // client-side consume check lowercases both sides, so the user-facing
        // error never mentioned the case mismatch -- they just got the
        // server's generic "Missing or insufficient permissions." trim+lower
        // on both sides mirrors the client check.
        allow read: if isSignedIn()
          && (isMember(estateId)
              || request.auth.token.email.trim().lower() == resource.data.inviteeEmail.trim().lower());
        // Create: executor of the parent estate only. Shape enforced via
        // required keys + type checks. FieldValue.serverTimestamp() is used
        // for createdAt by the client.
        allow create: if (isPlatformAdmin() || isMember(estateId))
          && (isPlatformAdmin() || get(/databases/$(database)/documents/estates/$(estateId)).data.roles[request.auth.uid] == 'executor')
          && request.resource.data.keys().hasAll(['inviteeEmail', 'role', 'createdBy', 'createdAt'])
          && request.resource.data.inviteeEmail is string
          && (request.resource.data.role in ['executor', 'heir', 'beneficiary'])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.createdAt is timestamp;
        // Update: the invitee claims the seat. Diff is restricted to ONLY
        // redeemedBy + redeemedAt so no other field can be smuggled in.
        // Phase 4 fix: same lowercase+trim email comparison as the read rule.
        allow update: if isSignedIn()
          && request.auth.token.email.trim().lower() == resource.data.inviteeEmail.trim().lower()
          && resource.data.redeemedBy == null
          && request.resource.data.redeemedBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['redeemedBy', 'redeemedAt']);
        // Delete: executor of the parent estate, and only an UNREDEEMED
        // invite (so revocation can't yank an already-claimed seat).
        allow delete: if (isPlatformAdmin() || isMember(estateId))
          && (isPlatformAdmin() || get(/databases/$(database)/documents/estates/$(estateId)).data.roles[request.auth.uid] == 'executor')
          && resource.data.redeemedBy == null;
      }
    }
  }
}
